# ============================================================
# Bootstrap 2 estágios para WLS V1:
# (1) reamostra base estratificado por tratamento
# (2) reestima propensity score dentro da amostra bootstrap (CV out-of-fold)
# (3) refaz matching
# (4) monta base matched + pesos ATT
# (5) roda WLS V1 e guarda distribuição dos coeficientes + IC percentil
# ============================================================

import numpy as np
import pandas as pd
import statsmodels.formula.api as smf
import matplotlib.pyplot as plt


# ---------- Helper: construir base "matched" + pesos ATT a partir dos pares ----------
def build_matched_att_from_pairs(
    df: pd.DataFrame,
    pairs: pd.DataFrame,
    *,
    id_col: str = "id",
    treat_col: str = "tratamento",
    outcome_col: str = "desfecho",
    treated_id_col: str = "treated_id",
    control_id_col: str = "control_id",
    k: int = 1,
    weight_scheme: str = "equal",   # "equal" = cada tratado contribui 1; se k>1, cada par pesa 1/k
    weight_col_out: str = "w_match",
):
    df0 = df.copy()

    if id_col not in df0.columns:
        df0 = df0.reset_index(drop=True)
        df0[id_col] = np.arange(len(df0))

    pairs0 = pairs.copy()
    pairs0[treated_id_col] = pairs0[treated_id_col].astype(int)
    pairs0[control_id_col] = pairs0[control_id_col].astype(int)

    treated_ids = pairs0[treated_id_col].unique()
    control_ids = pairs0[control_id_col].unique()

    df_t = df0[df0[id_col].isin(treated_ids)].copy()
    df_c = df0[df0[id_col].isin(control_ids)].copy()

    if weight_scheme == "equal":
        pair_w = 1.0 / float(k)
    else:
        raise ValueError(f"weight_scheme desconhecido: {weight_scheme}")

    # peso do controle = soma dos pesos dos pares em que ele aparece
    control_w = pairs0.groupby(control_id_col).size().rename("n_used").to_frame()
    control_w[weight_col_out] = control_w["n_used"] * pair_w

    # peso do tratado = 1
    df_t[weight_col_out] = 1.0

    # aplica aos controles
    df_c = df_c.merge(
        control_w[[weight_col_out]],
        left_on=id_col,
        right_index=True,
        how="left",
    )
    df_c[weight_col_out] = df_c[weight_col_out].fillna(0.0)

    df_matched = pd.concat([df_t, df_c], axis=0, ignore_index=True)

    if outcome_col not in df_matched.columns:
        raise ValueError(f"outcome_col='{outcome_col}' não está no dataframe.")
    if treat_col not in df_matched.columns:
        raise ValueError(f"treat_col='{treat_col}' não está no dataframe.")

    return df_matched


# ---------- Helper: roda WLS V1 (robust HC3) ----------
def run_wls_v1(
    df: pd.DataFrame,
    *,
    formula: str,
    weight_col: str | None = "w_match",
    robust_cov: str = "HC3",
):
    if weight_col is None:
        res = smf.ols(formula=formula, data=df).fit(cov_type=robust_cov)
        return res

    w = df[weight_col].astype(float).values
    res = smf.wls(formula=formula, data=df, weights=w).fit(cov_type=robust_cov)
    return res


# ============================================================
# PRINCIPAL: Bootstrap 2 estágios (PS-aware + matching-aware) para WLS V1
# ============================================================
def bootstrap_wls_v1_2stage(
    df_base: pd.DataFrame,
    *,
    # colunas
    id_col: str = "id",
    treat_col: str = "tratamento",
    outcome_col: str = "desfecho",
    ps_col: str = "propensity_score",

    # PS (2º estágio) - precisa existir no notebook: estimar_propensity_score(...)
    covariates: list | None = None,
    ps_n_splits: int = 5,

    # matching
    k: int = 1,
    with_replacement: bool = True,
    use_logit: bool = True,
    caliper: float | None = 0.2,
    caliper_scale: str = "sd",
    require_full_match: bool = True,
    strata_cols: list[str] | None = None,
    weight_scheme: str = "equal",

    # WLS V1
    formula: str = "desfecho ~ tratamento",
    robust_cov: str = "HC3",

    # bootstrap
    n_boot: int = 500,
    alpha: float = 0.05,
    random_state: int = 42,
    min_valid: int = 50,

    # quais coeficientes acompanhar (None = todos)
    coef_names: list[str] | None = None,

    # opcional: gráficos
    make_plots: bool = True,
):
    """
    Retorna:
      coef_df: DataFrame com coeficientes por réplica bootstrap (apenas válidas)
      summary_df: média, desvio e IC percentil (1-alpha) para cada coeficiente
    """

    rng = np.random.default_rng(random_state)

    df0 = df_base.copy()
    if df0.index.has_duplicates:
        df0 = df0.reset_index(drop=True)

    # garante id
    if id_col not in df0.columns:
        df0[id_col] = np.arange(len(df0))

    treated0 = df0[df0[treat_col] == 1].copy()
    control0 = df0[df0[treat_col] == 0].copy()
    n_t, n_c = len(treated0), len(control0)

    if n_t == 0 or n_c == 0:
        raise ValueError("Precisa haver tratados e controles em df_base.")

    boot_params = []
    valid = 0

    for b in range(n_boot):
        # 1) reamostra estratificado (mantém n_t e n_c)
        t_b = treated0.sample(n=n_t, replace=True, random_state=int(rng.integers(0, 2**31 - 1)))
        c_b = control0.sample(n=n_c, replace=True, random_state=int(rng.integers(0, 2**31 - 1)))
        df_b = pd.concat([t_b, c_b], axis=0).reset_index(drop=True)

        try:
            # 2) reestima PS dentro da amostra bootstrap (CV out-of-fold)
            df_b_ps = estimar_propensity_score(
                df_b,
                treat_col=treat_col,
                covariates=covariates,
                n_splits=ps_n_splits,
                seed=int(rng.integers(0, 2**31 - 1)),
            )

            # id único na amostra bootstrap (crítico!)
            df_b_ps[id_col] = np.arange(len(df_b_ps))
            df_b_ps = df_b_ps.set_index(id_col, drop=False)

            # 3) refaz matching
            pairs_b, _ = propensity_score_matching(
                df_b_ps,
                treat_col=treat_col,
                ps_col=ps_col,
                k=k,
                with_replacement=with_replacement,
                use_logit=use_logit,
                caliper=caliper,
                caliper_scale=caliper_scale,
                require_full_match=require_full_match,
                seed=int(rng.integers(0, 2**31 - 1)),
                strata_cols=strata_cols,
            )
            if pairs_b is None or len(pairs_b) == 0:
                continue

            # 4) monta matched sample + pesos ATT
            df_matched_b = build_matched_att_from_pairs(
                df_b_ps,
                pairs_b,
                id_col=id_col,
                treat_col=treat_col,
                outcome_col=outcome_col,
                treated_id_col="treated_id",
                control_id_col="control_id",
                k=k,
                weight_scheme=weight_scheme,
                weight_col_out="w_match",
            )

            # remove pesos zero
            df_matched_b = df_matched_b[df_matched_b["w_match"] > 0].copy()

            # 5) roda WLS V1
            res_b = run_wls_v1(
                df_matched_b,
                formula=formula,
                weight_col="w_match",
                robust_cov=robust_cov,
            )

            params_b = res_b.params.copy()
            if coef_names is not None:
                params_b = params_b.reindex(coef_names)

            boot_params.append(params_b)
            valid += 1

        except Exception:
            continue

    if valid < min_valid:
        raise ValueError(
            f"Poucas réplicas válidas: {valid}/{n_boot}. "
            "Sugestões: afrouxe caliper, use with_replacement=True, reduza k, "
            "ou use require_full_match=False."
        )

    coef_df = pd.DataFrame(boot_params)

    # resumo com IC percentil
    q_low = alpha / 2
    q_high = 1 - alpha / 2

    summary = []
    for col in coef_df.columns:
        s = coef_df[col].dropna()
        if s.shape[0] == 0:
            continue
        summary.append({
            "coef": col,
            "n": int(s.shape[0]),
            "mean": float(s.mean()),
            "std": float(s.std(ddof=1)) if s.shape[0] > 1 else np.nan,
            f"p{100*q_low:.1f}": float(np.quantile(s, q_low)),
            "p50": float(np.quantile(s, 0.50)),
            f"p{100*q_high:.1f}": float(np.quantile(s, q_high)),
        })
    summary_df = pd.DataFrame(summary).sort_values("coef").reset_index(drop=True)

    # plots
    if make_plots:
        for col in coef_df.columns:
            s = coef_df[col].dropna()
            if s.shape[0] == 0:
                continue
            plt.figure()
            plt.hist(s.values, bins=30)
            plt.title(f"Bootstrap 2-stage: distribuição do coeficiente '{col}'")
            plt.xlabel("coeficiente")
            plt.ylabel("frequência")
            plt.show()

    return coef_df, summary_df


